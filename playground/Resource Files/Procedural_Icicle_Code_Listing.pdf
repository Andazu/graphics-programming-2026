(  13: uniform float specularStrength;) Tj T*
(  14: uniform float shininess = 64.0f;) Tj T*
(  15: uniform float rimStrength;) Tj T*
(  16: uniform float alpha;) Tj T*
(  17: ) Tj T*
(  18: out vec4 FragColor;) Tj T*
(  19: ) Tj T*
(  20: void main\(\)) Tj T*
(  21: {) Tj T*
(  22:    vec3 norm = normalize\(Normal\);) Tj T*
(  23: ) Tj T*
(  24:    // Direction from fragment to light) Tj T*
(  25:    vec3 lightDir = normalize\(lightPos - FragPos\);) Tj T*
(  26: ) Tj T*
(  27:    // Direction from fragment to camera) Tj T*
(  28:    vec3 viewDir = normalize\(viewPos - FragPos\);) Tj T*
(  29: ) Tj T*
(  30:    // AMBIENT) Tj T*
(  31:    vec3 ambient = ambientStrength * lightColor;) Tj T*
(  32: ) Tj T*
(  33:    // DIFFUSE) Tj T*
(  34:    float diffuseAmount = max\(dot\(norm, lightDir\), 0.0\);) Tj T*
(  35:    vec3 diffuse = diffuseAmount * lightColor;) Tj T*
(  36: ) Tj T*
(  37:    // SPECULAR - Blinn-Phong) Tj T*
(  38:    vec3 halfwayDir = normalize\(lightDir + viewDir\);) Tj T*
(  39:    float specularAmount = pow\(max\(dot\(norm, halfwayDir\), 0.0\), shininess\);) Tj T*
(  40:    vec3 specular = specularStrength * specularAmount * lightColor;) Tj T*
(  41: ) Tj T*
(  42:    // RIM / FRESNEL-ISH EDGE GLOW) Tj T*
(  43:    float rimAmount = 1.0 - max\(dot\(norm, viewDir\), 0.0\);) Tj T*
(  44:    rimAmount = pow\(rimAmount, 2.0\);) Tj T*
(  45:    vec3 rim = rimAmount * rimStrength * vec3\(0.5, 0.85, 1.0\);) Tj T*
(  46: ) Tj T*
(  47:    vec3 result = \(ambient + diffuse\) * objectColor + specular + rim;) Tj T*
(  48: ) Tj T*
(  49:    FragColor = vec4\(result, alpha\);) Tj T*
(  50: }) Tj T*
() Tj T*
