( 183: void appendIcicleMesh\(MeshData& mesh, const glm::vec2& center, const IcicleSettings& settings, std::mt19937& rng\)) Tj T*
( 184: {) Tj T*
( 185:     std::uniform_real_distribution<float> randomRadius\(settings.minRadius, settings.maxRadius\);) Tj T*
( 186:     std::uniform_real_distribution<float> randomTipY\(settings.minTipY, settings.maxTipY\);) Tj T*
( 187:     std::uniform_real_distribution<float> randomTipOffset\(-0.06f, 0.06f\);) Tj T*
( 188:     std::uniform_real_distribution<float> randomShape\(0.75f, 1.25f\);) Tj T*
( 189: ) Tj T*
( 190:     const float centerX = center.x;) Tj T*
( 191:     const float centerZ = center.y;) Tj T*
( 192:     const float icicleRadius = randomRadius\(rng\);) Tj T*
( 193:     const float tipY = randomTipY\(rng\);) Tj T*
( 194:     const float tipOffsetX = randomTipOffset\(rng\);) Tj T*
( 195:     const float tipOffsetZ = randomTipOffset\(rng\);) Tj T*
( 196: ) Tj T*
( 197:     unsigned int tipIndex = getNextVertexIndex\(mesh\);) Tj T*
( 198: ) Tj T*
( 199:     // Tip vertex. The small x/z offset makes each icicle lean slightly.) Tj T*
( 200:     // position                         // normal) Tj T*
( 201:     mesh.vertices.insert\(mesh.vertices.end\(\), {) Tj T*
( 202:         centerX + tipOffsetX, tipY, centerZ + tipOffsetZ,) Tj T*
( 203:         0.0f, -1.0f, 0.0f) Tj T*
( 204:     }\);) Tj T*
( 205: ) Tj T*
( 206:     unsigned int ringStartIndex = getNextVertexIndex\(mesh\);) Tj T*
( 207: ) Tj T*
( 208:     // Top ring vertices) Tj T*
( 209:     for \(int i = 0; i < settings.segments; i++\)) Tj T*
( 210:     {) Tj T*
( 211:         float angle = \(2.0f * PI * i \) / settings.segments;) Tj T*
( 212:         float shapeNoise = randomShape\(rng\);) Tj T*
( 213: ) Tj T*
( 214:         float localX = std::cos\(angle\) * icicleRadius * shapeNoise;) Tj T*
( 215:         float localZ = std::sin\(angle\) * icicleRadius * shapeNoise;) Tj T*
ET
