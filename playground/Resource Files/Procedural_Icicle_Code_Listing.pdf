( 367:         VertexBufferObject vbo;) Tj T*
( 368:         vbo.Bind\(\);) Tj T*
( 369:         vbo.AllocateData<float>\(std::span\(sceneMesh.vertices\)\);) Tj T*
( 370: ) Tj T*
( 371:         // Element Buffer Object \(EBO\) - Part 3) Tj T*
( 372:         // Stores indicies that describe which vertices to draw - Indexed drawing!) Tj T*
( 373:         ElementBufferObject ebo;) Tj T*
( 374:         ebo.Bind\(\);) Tj T*
( 375:         ebo.AllocateData<unsigned int>\(std::span\(sceneMesh.indices\)\);) Tj T*
( 376: ) Tj T*
( 377:         // The position attribute is made of 3 floats: x, y, z) Tj T*
( 378:         VertexAttribute position\(Data::Type::Float, 3\);) Tj T*
( 379:         // Use shader location 0, read 3 floats \(x,y,z\) start at byte offset 0, jump one full vertex to get to the next position) Tj T*
( 380:         vao.SetAttribute\(0, position, 0, FLOATS_PER_VERTEX * sizeof\(float\)\);) Tj T*
( 381: ) Tj T*
( 382:         // The normal attribute is made of 3 floats: nx, ny, nz) Tj T*
( 383:         VertexAttribute normalV\(Data::Type::Float, 3\);) Tj T*
( 384:         // Use shader location 1, read 3 floats after the position, jump one full vertex to get to the next normal) Tj T*
( 385:         vao.SetAttribute\(1, normalV, 3 * sizeof\(float\), FLOATS_PER_VERTEX * sizeof\(float\)\);) Tj T*
( 386: ) Tj T*
( 387:         // note that this is allowed, the call to glVertexAttribPointer registered VBO as the vertex attribute's bound vertex buffer object so afterwards ) Tj T*
(      | we can safely unbind) Tj T*
( 388:         VertexBufferObject::Unbind\(\);) Tj T*
